# =========================================================================
# Factory Health Agent — environment configuration
# Copy to `.env` and fill in. ALL values are optional: any component
# without credentials automatically falls back to a local in-memory /
# mock implementation so the platform runs end-to-end with zero setup.
# =========================================================================

# --- LLM providers (primary: Azure OpenAI, fallback: Gemini) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
OPENAI_API_VERSION=2024-08-01-preview

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Observability (LangSmith) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=factory-health-agent

# --- Data layer ---
# Leave MONGODB_URI empty to use the in-memory store.
MONGODB_URI=
MONGODB_DB=factory_health
# Leave REDIS_URL empty to use the in-memory budget/rate-limit store.
REDIS_URL=
# Leave CHROMA_HOST empty to use a local persistent / in-memory Chroma.
CHROMA_HOST=
CHROMA_PORT=8000
CHROMA_PERSIST_DIR=./chroma_data

# --- API security ---
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=100

# --- Defaults ---
DEFAULT_TENANT_BUDGET_USD=10.0
